# 服务端口（Nginx 反代时可保持 3004 仅内网监听）
PORT=3004

# DeepSeek API Key（可选，驾车通勤估算；不填或余额不足时自动降级本地估算）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 高德地图 Web 服务 Key（推荐，公交/地铁 + 近距离步行；配置后默认使用 transit 模式）
GAODE_API_KEY=your_gaode_api_key_here

# 高德 API 限速（次/秒，免费版建议 1；避免 CUQPS_HAS_EXCEEDED_THE_LIMIT）
GAODE_QPS=1

# 数据库（当前 Web 派单以内存会话为主，此项可保留默认）
DATABASE_URL="file:./dev.db"
