{
  "name": "dispatch-system",
  "version": "1.0.0",
  "description": "招商派单系统 - 自动分配客户拜访任务给员工",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:web": "node dist/server.js",
    "dev": "tsx src/index.ts",
    "web": "tsx src/server.ts",
    "web:3005": "tsx src/server.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dispatch": "tsx src/index.ts",
    "import": "tsx src/scripts/import-data.ts",
    "cache:showcase": "tsx scripts/cache-showcase.ts",
    "cache:sample-data": "tsx scripts/cache-sample-data.ts",
    "test:match-report": "tsx scripts/generate-match-test-report.ts",
    "validate:matches": "tsx scripts/validate-all-matches.ts",
    "validate:scenarios": "tsx scripts/scan-match-scenarios.ts",
    "test:transit-scenarios": "tsx scripts/test-transit-scenarios.ts",
    "compare:dispatch": "tsx scripts/compare-dispatch-results.ts",
    "compare:employee": "tsx scripts/compare-employee-roster.ts",
    "compare:rationale": "tsx scripts/compare-roster-rationale.ts",
    "deploy": "bash deploy/deploy.sh"
  },
  "keywords": [
    "dispatch",
    "派单",
    "招商"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.22.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "optionalDependencies": {
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0"
  }
}
